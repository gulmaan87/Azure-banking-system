# Azure Bank Portal — Environment Variables
# Rename to .env and fill in your values from Azure Portal

# ── Azure AD App Registration ────────────────────────────────────────────────
# Portal → Azure Active Directory → App Registrations → "Azure Bank Portal"
VITE_AZURE_TENANT_ID=your-tenant-id-here
VITE_AZURE_CLIENT_ID=your-portal-app-client-id-here

# App Registration for the Backend API ("azure-bank-api")
VITE_AZURE_API_CLIENT_ID=your-api-app-client-id-here

# ── Azure AD Group Object IDs ────────────────────────────────────────────────
# Portal → Azure Active Directory → Groups → click group → copy "Object ID"
VITE_GROUP_BANK_ADMINS=your-bank-admins-group-object-id
VITE_GROUP_SECURITY_AUDITORS=your-security-auditors-group-object-id
VITE_GROUP_APP_DEVELOPERS=your-app-developers-group-object-id
VITE_GROUP_DATA_ENGINEERS=your-data-engineers-group-object-id

# ── Backend API URL ──────────────────────────────────────────────────────────
# Local dev: http://localhost:3001/api
# Production (corebank-1 VM): https://your-api-domain/api
VITE_API_URL=http://localhost:3001/api
