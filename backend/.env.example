# Azure Bank Backend API — Environment Variables
# Copy this to .env and fill in your real values

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Azure AD (Employee Auth) ─────────────────────────────────
# Get these from: Azure Portal → App Registrations → "azure-bank-api"
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-api-app-client-id-here

# Azure AD Group Object IDs (from Terraform outputs or Azure Portal)
AZURE_GROUP_BANK_ADMINS=your-bank-admins-group-object-id
AZURE_GROUP_SECURITY_AUDITORS=your-security-auditors-group-object-id
AZURE_GROUP_APP_DEVELOPERS=your-app-developers-group-object-id
AZURE_GROUP_DATA_ENGINEERS=your-data-engineers-group-object-id

# ── Database ─────────────────────────────────────────────────
# For local dev, use localhost. On VM, use 10.0.6.4 (database-1)
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=BankingDB
DB_USER=bankapp
DB_PASSWORD=YourStrong@Passw0rd

# ── Azure Key Vault (Production only) ───────────────────────
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# ── Azure Storage (for KYC documents) ───────────────────────
STORAGE_ACCOUNT_NAME=mohdggulmaanbankr1
STORAGE_CONTAINER_KYC=kyc-documents

# ── Azure SignalR (Real-time alerts) ────────────────────────
SIGNALR_CONNECTION_STRING=your-signalr-connection-string

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
